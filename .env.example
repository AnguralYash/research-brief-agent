# Copy this file to `.env` and fill in a key, OR just export these in your shell.
# The agent auto-loads a `.env` file from the project root if present.

# ── Which provider to use ──────────────────────────────────────────────
# One of: gemini (default) | anthropic | openai | groq | ollama
LLM_PROVIDER=gemini

# Optional: override the model. Sensible per-provider defaults are used if unset.
#   gemini    -> gemini-2.5-flash
#   anthropic -> claude-haiku-4-5
#   openai    -> gpt-4o-mini
#   groq      -> llama-3.3-70b-versatile
#   ollama    -> llama3.1
# LLM_MODEL=gemini-2.5-flash

# ── API keys (set the one matching your provider) ──────────────────────
# Free, no credit card: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=            # free, no card: https://console.groq.com/keys
# Ollama needs no key; runs locally. Optionally set OLLAMA_HOST (default http://localhost:11434).
